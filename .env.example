# ArduPhotoLogger Environment Configuration

# PostgreSQL Connection Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=arduphotologger
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Sync Worker Settings
# Sync interval in milliseconds (default: 30000 = 30 seconds)
SYNC_INTERVAL_MS=30000

# Batch size for syncing events (default: 50)
SYNC_BATCH_SIZE=50

# Maximum retry attempts before giving up (default: 5)
SYNC_MAX_RETRIES=5

# Hours to keep synced records before cleanup (default: 24)
SYNC_CLEANUP_HOURS=24

# Enable/disable sync worker (default: true)
SYNC_ENABLED=true
